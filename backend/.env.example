# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Server
NODE_ENV=production
PORT=5000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# JWT — generate strong random secrets (e.g. openssl rand -base64 64)
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Zoom (Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# Cloudflare R2 (blog images) — Account ID + an API token scoped to R2,
# from the Cloudflare dashboard: R2 -> Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ualms
# Leave blank to serve images through our own backend instead of a public
# R2 URL. If you enable the bucket's r2.dev public access (or attach a
# custom domain later), paste that base URL here, e.g.:
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL=
